@model DevelopTest.Models.SportArea

<div class="page-header">
    <div>
        <h1 class="page-title">Sport Area Details</h1>
        <p class="page-subtitle">Facility information</p>
    </div>
    <a asp-action="Edit" asp-controller="SportArea" asp-route-id="@Model.Id" class="btn-primary-custom">Edit</a>
</div>

<div class="detail-card">
    <div class="detail-row">
        <span class="detail-label">ID</span>
        <span class="detail-value">@Model.Id</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Name</span>
        <span class="detail-value">@Model.Name</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Type</span>
        <span class="detail-value">@Model.Type</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Schedule</span>
        <span class="detail-value">@Model.OpeningTime – @Model.ClosingTime</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Capacity</span>
        <span class="detail-value">@Model.Capacity people</span>
    </div>
</div>

<a asp-action="Index" asp-controller="SportArea" class="back-link">← Back to Sport Areas</a>