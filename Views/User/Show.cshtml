@model DevelopTest.Models.User

<div class="page-header">
    <div>
        <h1 class="page-title">User Details</h1>
        <p class="page-subtitle">Member profile information</p>
    </div>
    <a asp-action="Edit" asp-controller="User" asp-route-id="@Model.Id" class="btn-primary-custom">Edit</a>
</div>

<div class="detail-card">
    <div class="detail-row">
        <span class="detail-label">ID</span>
        <span class="detail-value">@Model.Id</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Name</span>
        <span class="detail-value">@Model.Name</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Document</span>
        <span class="detail-value">@Model.Document</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Email</span>
        <span class="detail-value">@Model.Email</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Phone</span>
        <span class="detail-value">@Model.Phone</span>
    </div>
</div>

<a asp-action="Index" asp-controller="User" class="back-link">← Back to Users</a>