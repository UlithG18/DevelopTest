@model DevelopTest.Models.User

<div class="page-header">
    <div>
        <h1 class="page-title">New User</h1>
        <p class="page-subtitle">Register a new club member</p>
    </div>
</div>

<div class="form-card">
    <form asp-action="Store" asp-controller="User" method="post">
        <div class="mb-3">
            <label class="form-label" asp-for="Name">Full Name</label>
            <input asp-for="Name" class="form-control" type="text" placeholder="e.g. María Fernanda López" />
        </div>
        <div class="mb-3">
            <label class="form-label" asp-for="Document">Document</label>
            <input asp-for="Document" class="form-control" type="text" placeholder="0000000000" />
        </div>
        <div class="mb-3">
            <label class="form-label" asp-for="Email">Email</label>
            <input asp-for="Email" type="email" class="form-control" placeholder="name@example.com" />
        </div>
        <div class="mb-3">
            <label class="form-label" asp-for="Phone">Phone</label>
            <input asp-for="Phone" type="text" class="form-control" placeholder="3001234567" />
        </div>
        <div class="form-actions">
            <button type="submit" class="btn-primary-custom">Register Member</button>
            <a asp-action="Index" asp-controller="User" class="btn-ghost-custom">Cancel</a>
        </div>
    </form>
</div>